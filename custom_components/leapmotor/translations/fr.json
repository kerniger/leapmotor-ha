          "app_key_pem": "Paste app_key.pem PEM (private key)",
          "operation_password": "PIN vehicule (optionnel, pour le controle)",
          "scan_interval": "Intervalle de mise a jour en minutes"
        }
      },
      "init": {
        "title": "Options Leapmotor",
